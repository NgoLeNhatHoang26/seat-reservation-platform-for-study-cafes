NODE_ENV=test

# DB test — tách khỏi dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/cafe_reservation_test
REDIS_URL=redis://localhost:6380/1

# JWT — secret riêng cho test (không dùng production)
JWT_ACCESS_SECRET=test-access-secret
JWT_REFRESH_SECRET=test-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

PORT=3001
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Các biến optional — để trống cũng được
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@test.local
ADMIN_NOTIFICATION_EMAIL=admin@test.local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=