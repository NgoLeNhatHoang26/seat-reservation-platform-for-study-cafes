# ── Database (required) ──────────────────────────────────────
# Docker Compose maps Postgres to host port 5434
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/cafe_reservation

# ── Redis (required) ─────────────────────────────────────────
# Docker Compose maps Redis to host port 6381 (container 6379)
REDIS_URL=redis://localhost:6381

# ── JWT (required) ───────────────────────────────────────────
# Use long random secrets in production — never commit real values
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# CORS — comma-separated origins (Vite dev server)
ALLOWED_ORIGINS=http://localhost:5173

# Frontend URL (used in email verification / deep links)
FRONTEND_URL=http://localhost:5173

# ── SendGrid (optional — empty = skip email send) ────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com
# Inbox for "new café pending approval" admin alerts
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# ── Cloudinary (optional — empty = upload features disabled) ─
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
